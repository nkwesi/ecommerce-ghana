# Database
# Supabase: copy the Session pooler URI from Dashboard > Connect.
# Keep this secret on the backend. Never expose it as NEXT_PUBLIC_*.
DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_CA_CERT_BASE64=
DATABASE_POOL_MAX=10

# Local PostgreSQL fallback when DATABASE_URL is empty
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ecommerce_ghana
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Application
NODE_ENV=development
PORT=3001
API_VERSION=v1
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
ADMIN_SETUP_KEY=replace_with_a_one_time_random_secret
ADMIN_SETUP_ENABLED=true

# Payment - use demo locally and paystack in production
PAYMENT_MODE=demo
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYMENT_TEST_ENDPOINTS_ENABLED=true

# Business Configuration
COUNTRY_CODE=GH
CURRENCY=GHS
# Confirm with an accountant. Use 0 if displayed prices are tax-inclusive.
VAT_RATE=0
DEFAULT_RESERVATION_MINUTES=10
STOCK_SAFETY_BUFFER=1

# Email / order notifications
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Product image storage. Keep the service role key on the backend only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
PRODUCT_IMAGES_BUCKET=product-images
